Algoritmo Laboratorio
	
	// Declarar la variable numero como un entero
	Definir numero Como Entero
	
	// Pedir el número inicial
	Escribir "Ingrese un número mayor o igual a 0:" 
	Leer numero
	
	// Ciclo Repetir - Hasta Que
	Repetir
		
		// Mostrar el número actual
		Escribir "Número: ", numero
		
		// Restar 2
		numero <- numero - 2
		
	Hasta Que numero < 0  // El ciclo termina cuando el número es menor que 0
	
FinAlgoritmo