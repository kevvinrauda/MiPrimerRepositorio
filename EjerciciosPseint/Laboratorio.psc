Algoritmo Laboratorio
	
	// Declarar variable numero como enteri
	Definir numero Como Entero
	
	// Pedir número al usuario
	Escribir "Ingrese un número mayor o igual a 0:"
	Leer numero
	
	// Ciclo Mientras
	Mientras numero >= 0 Hacer
		
		// Mostrar número actual
		Escribir "Número: ", numero
		
		// Restar 2
		numero <- numero - 2
		
	Fin Mientras
	
FinAlgoritmo