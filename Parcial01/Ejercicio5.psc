Algoritmo Ejercicio5
	
	//Definir numero
	Definir n Como Entero
	
	Escribir "Ingrese un numero del 1 al 10: "
	Leer n
	
	//BUCLE MIENTRAS PARA VERIFICAR QUE EL NUMERO SEA DENTRO DEL RANGO 0-10
		Mientras n <= 10 Y n >= 0 Hacer
			Escribir "Correcto, ingrese nuevamente otro numero"
			leer n
		Fin Mientras

		Escribir "Numero invalido. Fin del programa."
		
		//KevinRauda
FinAlgoritmo
