Algoritmo Ejercicio4
	
	Definir n, i Como Entero
	//Definir variables
	// n como la dantidad de numeros que desea el usuario ver
	//i como contador
	
	Escribir "Ingrese la cantidad de numeros pares que desea ver:"
	Leer n
	
	//Empieza en 1 repite hasta n
	Para i <- 1 Hasta n Hacer
		//Multiplicamos i por dos, para asi sacar numeros pares
		//EJEMPLO:  1 X 2 = 2
		//          2 X 2 = 4
		//          3 X 2 = 6
		Escribir i * 2
	FinPara

	//KevinRauda
FinAlgoritmo
